---
import MainLayout from "../layouts/MainLayout.astro";
import InquiryForm from "../components/InquiryForm.astro";
import EntryGrid from "../components/EntryGrid.astro";
import Carousel from "../components/Carousel.astro";
import { homeContent } from "../data/home-content";
import { getHomeEntry, getLatest } from "../lib/site";

const home = getHomeEntry();
const latestProducts = getLatest("product", 8);
---

<MainLayout title="Home - Wuxi Sharing Machinery Co.,Ltd" description={home.description} image={home.image}>
  <section class="section-lg relative overflow-hidden bg-[#0b1d33] text-white" data-reveal="fade">
    {homeContent.hero.image ? (
      <img
        src={homeContent.hero.image}
        alt=""
        class="absolute inset-0 h-full w-full object-cover opacity-25"
        fetchpriority="high"
      />
    ) : null}
    <div class="absolute inset-0 bg-gradient-to-br from-[#0b1d33]/90 via-[#0f2440]/80 to-[#0b1d33]/95"></div>
    <div class="pixel-container relative z-10 text-center">
      <h1 class="mx-auto max-w-[840px] text-[36px] font-bold leading-tight text-white md:text-[42px]">
        {homeContent.hero.title}
      </h1>
      <div class="mx-auto mt-[16px] h-[3px] w-[58px] bg-[var(--site-green)]"></div>
      <ul class="mx-auto mt-[24px] max-w-[760px] list-disc text-left text-[15px] leading-[1.65] text-white/85">
        {homeContent.hero.bullets.map((item) => <li>{item}</li>)}
      </ul>
      <div class="mt-[34px] flex flex-wrap items-center justify-center gap-[16px]">
        <a href={homeContent.hero.primaryHref} class="btn-primary">
          {homeContent.hero.primaryLabel} <span class="text-[13px]">&gt;</span>
        </a>
      </div>

      <div class="mx-auto mt-[42px] grid max-w-[840px] grid-cols-2 gap-x-[34px] gap-y-[28px] sm:grid-cols-4">
        {homeContent.showcaseItems.map((item) => (
          <a href={item.href} class="group text-center">
            <div class="relative mx-auto h-[160px] w-[160px] overflow-hidden rounded-full bg-[#d8d8d8] shadow-[0_2px_4px_rgba(0,0,0,0.16)]">
              <img
                src={item.image}
                alt={item.title}
                class="h-full w-full object-cover grayscale transition duration-300 group-hover:grayscale-0"
              />
              <div class="absolute inset-x-0 bottom-0 h-[52px] rounded-t-[80%] bg-[var(--site-blue)]"></div>
              <div class="showcase-label absolute inset-x-2 bottom-[18px] truncate text-[13px] font-bold text-white">
                {item.title}
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section-sm pixel-container relative z-10 -mt-[56px] grid bg-white px-[35px] shadow-[0_26px_58px_rgba(0,0,0,0.18)] md:grid-cols-3" data-reveal="fade-up" data-reveal-delay="100">
    {homeContent.highlights.map((item, index) => (
      <article class={`px-[34px] text-center ${index === 1 ? "md:border-x md:border-[#eeeeee]" : ""}`}>
        <h2 class="text-[25px] font-bold uppercase text-[var(--site-heading)]">{item.title}</h2>
        <p class="mt-[18px] text-left text-[14px] leading-[1.6] text-[#777]">{item.body}</p>
      </article>
    ))}
  </section>

  <section class="section-lg pixel-container grid gap-[70px] md:grid-cols-[1fr_1.08fr] md:items-start" data-reveal="fade-up">
    <div>
      <h2 class="site-section-title">What We Do</h2>
      <p class="mt-[32px] text-[15px] leading-[1.7] text-[#666]">{homeContent.intro.body}</p>
    </div>
    <div class="overflow-hidden rounded-[4px] shadow-[0_9px_18px_rgba(0,0,0,0.24)]">
      <img src={homeContent.intro.image} alt="Sharing laundry exhibition" class="aspect-[1.55] w-full object-cover" />
    </div>
  </section>

  <section class="section-md relative overflow-hidden bg-cover bg-center bg-no-repeat text-white" style="background-image: url('/wp-assets/uploads/img-bg-laundry.jpg');" data-reveal="fade-up">
    <div class="absolute inset-0 bg-[#0b1d33]/80"></div>
    <div class="pixel-container relative z-10 grid gap-[76px] md:grid-cols-[1fr_1fr]">
      <div>
        <h2 class="site-section-title">Why Choose Us</h2>
        <div class="mt-[42px] grid gap-x-[30px] gap-y-[34px] sm:grid-cols-2">
          {homeContent.reasons.map((reason, index) => (
            <article class="grid grid-cols-[44px_1fr] gap-[15px]">
              <div class="blue-icon-dot">{index + 1}</div>
              <div>
                <h3 class="text-[15px] font-bold text-[var(--site-blue-dark)]">{reason.title}</h3>
                <p class="mt-[8px] text-[14px] leading-[1.6] text-white/90">
                  {reason.body}
                </p>
              </div>
            </article>
          ))}
        </div>
      </div>
      <InquiryForm compact={true} />
    </div>
  </section>

  <section class="section-lg" data-reveal="fade-up">
    <div class="pixel-container text-center">
      <h2 class="site-section-title mx-auto w-fit text-center">Cooperative Partners</h2>
      <p class="mt-[34px] text-[13px] font-bold tracking-[0.24em] text-[var(--site-blue)]">
        {homeContent.partnersTitle}
      </p>
      <div class="mt-[34px]">
        <Carousel id="partners" autoplay={3500} itemsPerView={5} itemsPerViewTablet={3} itemsPerViewMobile={2} gap={10}>
          {homeContent.partnerLogos.map((logo, index) => (
            <div class="flex h-[126px] items-center justify-center rounded-[4px] border border-[#cfcfcf] bg-white p-[10px]">
              <img src={logo} alt={`Cooperative partner ${index + 1}`} class="max-h-full max-w-full object-contain" loading="lazy" />
            </div>
          ))}
        </Carousel>
      </div>
    </div>
  </section>

  <section class="section-md bg-[#f2f2f2]" data-reveal="fade-up">
    <div class="pixel-container">
      <h2 class="site-section-title">Our Customer Say</h2>
      <div class="mt-[50px]">
        <Carousel id="testimonials" autoplay={5000} itemsPerView={2} itemsPerViewMobile={1} gap={32}>
          {homeContent.testimonials.map((item) => (
            <article class="border-b-[5px] border-[var(--site-green)] pb-[27px]">
              <div class="mb-[13px] text-[34px] font-black leading-none text-[var(--site-blue)]">"</div>
              <p class="text-[15px] leading-[1.7] text-[#666]">{item.quote}</p>
              <div class="mt-[21px] flex items-center gap-[12px]">
                <img src={item.image} alt={item.author} class="h-[48px] w-[48px] rounded-full object-cover" loading="lazy" />
                <div>
                  <div class="text-[14px] font-bold text-[var(--site-blue)]">{item.author}</div>
                  <div class="text-[13px] text-[#777]">{item.role}</div>
                </div>
              </div>
            </article>
          ))}
        </Carousel>
      </div>
    </div>
  </section>

  <section class="section-md slanted-bg bg-white text-center" data-reveal="fade-up">
    <div class="pixel-container">
      <div class="text-[13px] font-bold uppercase tracking-[0.22em] text-[var(--site-blue)]">{homeContent.hotline.eyebrow}</div>
      <div class="mt-[16px] text-[28px] font-bold text-[var(--site-blue)]">{homeContent.hotline.phone}</div>
      <div class="mx-auto mt-[16px] h-[3px] w-[58px] bg-[var(--site-green)]"></div>
      <div class="mt-[24px] text-[14px] font-bold tracking-[0.22em] text-[var(--site-blue)]">{homeContent.hotline.title}</div>
      <a href={homeContent.hotline.href} class="btn-primary mt-[25px]">{homeContent.hotline.label} <span>&gt;</span></a>
    </div>
  </section>

  <section class="section-md bg-[#f4f8fc]" data-reveal="fade-up">
    <div class="pixel-container">
      <EntryGrid title="Products" entries={latestProducts.slice(0, 6)} />
    </div>
  </section>
</MainLayout>
