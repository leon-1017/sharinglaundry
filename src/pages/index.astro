---
import MainLayout from "../layouts/MainLayout.astro";
import InquiryForm from "../components/InquiryForm.astro";
import EntryGrid from "../components/EntryGrid.astro";
import { homeContent } from "../data/home-content";
import { getHomeEntry, getLatest } from "../lib/site";

const home = getHomeEntry();
const latestProducts = getLatest("product", 8);
---

<MainLayout title="Home - Wuxi Sharing Machinery Co.,Ltd" description={home.description} image={home.image}>
  <section class="slanted-bg bg-white pb-[80px] pt-[66px]">
    <div class="pixel-container text-center">
      <h1 class="mx-auto max-w-[760px] text-[30px] font-bold leading-tight text-[var(--site-blue)] md:text-[33px]">
        {homeContent.hero.title}
      </h1>
      <div class="mx-auto mt-[13px] h-[3px] w-[58px] bg-[var(--site-green)]"></div>
      <ul class="mx-auto mt-[21px] max-w-[760px] list-disc text-left text-[13px] leading-[1.45] text-[#666]">
        {homeContent.hero.bullets.map((item) => <li>{item}</li>)}
      </ul>
      <a href={homeContent.hero.primaryHref} class="btn-primary mt-[30px]">
        See More Products <span class="text-[13px]">&gt;</span>
      </a>

      <div class="mx-auto mt-[38px] grid max-w-[760px] grid-cols-2 gap-x-[34px] gap-y-[28px] sm:grid-cols-4">
        {homeContent.showcaseItems.map((item) => (
          <a href={item.href} class="group text-center">
            <div class="relative mx-auto h-[138px] w-[138px] overflow-hidden rounded-full bg-[#d8d8d8] shadow-[0_2px_4px_rgba(0,0,0,0.16)]">
              <img src={item.image} alt={item.title} class="h-full w-full object-cover grayscale-[0.08]" />
              <div class="absolute inset-x-0 bottom-0 h-[48px] rounded-t-[80%] bg-[var(--site-blue)]"></div>
              <div class="absolute inset-x-2 bottom-[16px] truncate text-[10px] font-bold text-white">{item.title}</div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="pixel-container relative z-10 -mt-[56px] grid bg-white px-[35px] py-[42px] shadow-[0_26px_58px_rgba(0,0,0,0.18)] md:grid-cols-3">
    {homeContent.highlights.map((item, index) => (
      <article class={`px-[34px] text-center ${index === 1 ? "md:border-x md:border-[#eeeeee]" : ""}`}>
        <div class="mx-auto mb-[17px] flex h-[44px] w-[44px] items-center justify-center rounded-full text-[25px] font-black text-[var(--site-blue)]">
          {index === 0 ? "Q" : index === 1 ? "E" : "$"}
        </div>
        <h2 class="text-[25px] font-bold uppercase text-[var(--site-blue)]">{item.title}</h2>
        <p class="mt-[18px] text-left text-[12px] leading-[1.55] text-[#777]">{item.body}</p>
      </article>
    ))}
  </section>

  <section class="pixel-container grid gap-[70px] py-[98px] md:grid-cols-[1fr_1.08fr] md:items-start">
    <div>
      <h2 class="site-section-title">What We Do</h2>
      <p class="mt-[32px] text-[13px] leading-[1.5] text-[#666]">{homeContent.intro.body}</p>
    </div>
    <div class="overflow-hidden rounded-[4px] shadow-[0_9px_18px_rgba(0,0,0,0.24)]">
      <img src={homeContent.intro.image} alt="Sharing laundry exhibition" class="aspect-[1.55] w-full object-cover" />
    </div>
  </section>

  <section class="bg-[var(--site-gray-band)] py-[78px] text-white">
    <div class="pixel-container grid gap-[76px] md:grid-cols-[1fr_1fr]">
      <div>
        <h2 class="site-section-title !text-[var(--site-blue)]">Why Choose Us</h2>
        <div class="mt-[42px] grid gap-x-[30px] gap-y-[34px] sm:grid-cols-2">
          {homeContent.reasons.map((reason, index) => (
            <article class="grid grid-cols-[44px_1fr] gap-[15px]">
              <div class="blue-icon-dot">{index + 1}</div>
              <div>
                <h3 class="text-[13px] font-bold text-[var(--site-blue)]">{reason}</h3>
                <p class="mt-[8px] text-[12px] leading-[1.45] text-white/90">
                  We provide focused support and dependable communication for commercial laundry project decisions.
                </p>
              </div>
            </article>
          ))}
        </div>
      </div>
      <InquiryForm compact={true} />
    </div>
  </section>

  <section class="py-[86px]">
    <div class="pixel-container text-center">
      <h2 class="site-section-title mx-auto w-fit text-center">Cooperative Partners</h2>
      <p class="mt-[34px] text-[12px] font-bold tracking-[0.24em] text-[var(--site-blue)]">
        {homeContent.partnersTitle}
      </p>
      <div class="mt-[34px] grid gap-[10px] sm:grid-cols-5">
        {homeContent.partnerLogos.map((logo, index) => (
          <div class="flex h-[126px] items-center justify-center rounded-[4px] border border-[#cfcfcf] bg-white p-[10px]">
            <img src={logo} alt={`Cooperative partner ${index + 1}`} class="max-h-full max-w-full object-contain" loading="lazy" />
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-[#f2f2f2] py-[78px]">
    <div class="pixel-container">
      <h2 class="site-section-title">Our Customer Say</h2>
      <div class="mt-[66px] grid gap-x-[50px] gap-y-[64px] md:grid-cols-2">
        {homeContent.testimonials.map((item) => (
          <article class="border-b-[5px] border-[var(--site-green)] pb-[27px]">
            <div class="mb-[13px] text-[34px] font-black leading-none text-[var(--site-blue)]">"</div>
            <p class="text-[13px] leading-[1.55] text-[#666]">{item.quote}</p>
            <div class="mt-[21px] flex items-center gap-[12px]">
              <img src={item.image} alt={item.author} class="h-[48px] w-[48px] rounded-full object-cover" loading="lazy" />
              <div>
                <div class="text-[12px] font-bold text-[var(--site-blue)]">{item.author}</div>
                <div class="text-[10px] text-[#777]">{item.role}</div>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="slanted-bg bg-white py-[82px] text-center">
    <div class="pixel-container">
      <div class="text-[11px] font-bold uppercase tracking-[0.22em] text-[var(--site-blue)]">{homeContent.hotline.eyebrow}</div>
      <div class="mt-[16px] text-[28px] font-bold text-[var(--site-blue)]">{homeContent.hotline.phone}</div>
      <div class="mx-auto mt-[16px] h-[3px] w-[58px] bg-[var(--site-green)]"></div>
      <div class="mt-[24px] text-[12px] font-bold tracking-[0.22em] text-[var(--site-blue)]">{homeContent.hotline.title}</div>
      <a href={homeContent.hotline.href} class="btn-primary mt-[25px]">Contact Our Team <span>&gt;</span></a>
    </div>
  </section>

  <section class="bg-[#f4f8fc] py-[70px]">
    <div class="pixel-container">
      <EntryGrid title="Products" entries={latestProducts.slice(0, 6)} />
    </div>
  </section>
</MainLayout>
