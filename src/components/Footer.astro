---
import { productCategories } from "../data/navigation";
---

<footer class="bg-white text-[#777]">
  <div class="pixel-container grid gap-12 py-[58px] md:grid-cols-[280px_260px_1fr]">
    <div>
      <a href="/" class="block w-[220px] max-w-full">
        <img src="/wp-assets/uploads/250X100.png" alt="Wuxi Sharing Machinery Co.,Ltd" class="h-auto w-full" />
      </a>
    </div>

    <div>
      <h3 class="mb-5 text-[22px] font-bold text-[var(--site-blue)]">Products</h3>
      <nav class="grid gap-[13px]">
        {productCategories.map((item) => (
          <a href={item.href} class="text-[13px] font-semibold uppercase text-[#777] hover:text-[var(--site-blue)]">{item.label}</a>
        ))}
      </nav>
    </div>

    <div>
      <h3 class="mb-5 text-[22px] font-bold text-[var(--site-blue)]">Contact us</h3>
      <div class="grid gap-[11px] text-[14px]">
        <p>No.588, Nanhu Avenue, Wuxi City, China</p>
        <p>+86-51066206136</p>
        <p>+86-13606196136</p>
        <p>info@sharinglaundry.com</p>
        <a href="https://wa.me/+8613606196136" class="mt-1 inline-flex w-fit items-center rounded-[3px] bg-[#00aa7e] px-5 py-[7px] text-[13px] font-bold text-white">Chat on WhatsApp</a>
        <a href="skype:jiaqifu1986?chat" class="inline-flex w-fit items-center rounded-[3px] bg-[#0a74d1] px-5 py-[7px] text-[13px] font-bold text-white">Chat on Skype</a>
      </div>
    </div>
  </div>
  <div class="pixel-container flex flex-col gap-3 pb-9 text-[13px] text-[#777] md:flex-row md:items-center md:justify-between">
    <div>Copyright © 2026 Wuxi Sharing Machinery Co.,Ltd</div>
    <div class="flex gap-2">
      <a href="https://www.facebook.com/profile.php?id=100011834623780" class="flex h-5 w-5 items-center justify-center bg-[#8e8e8e] text-[12px] font-bold text-white">f</a>
      <a href="https://www.linkedin.com/in/mark-jia-364601b8?trk=nav_responsive_tab_profile_pic" class="flex h-5 w-5 items-center justify-center bg-[#8e8e8e] text-[12px] font-bold text-white">in</a>
    </div>
  </div>
</footer>
