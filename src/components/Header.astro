---
import { mainNavigation } from "../data/navigation";
---

<header class="sticky top-0 z-40 bg-white">
  <div class="pixel-container flex h-[126px] items-start justify-between pt-[31px]">
    <a href="/" class="flex w-[170px] items-center pt-0">
      <img src="/wp-assets/uploads/250X100.png" alt="Wuxi Sharing Machinery Co.,Ltd" class="h-auto w-full" />
    </a>

    <nav class="hidden items-center gap-[34px] pt-[18px] lg:flex">
      {
        mainNavigation.map((item) =>
          item.children ? (
            <div class="group relative">
              <a href={item.href} class="inline-flex items-center gap-[6px] text-[14px] font-semibold uppercase leading-none text-[#777] transition hover:text-[var(--site-blue)]">
                {item.label}
                <svg class="h-[10px] w-[10px] fill-current transition-transform duration-200 group-hover:rotate-180" viewBox="0 0 20 20" aria-hidden="true">
                  <path d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" />
                </svg>
              </a>
              <div class="pointer-events-none invisible absolute left-0 top-full w-56 pt-2 opacity-0 transition-all duration-150 group-hover:pointer-events-auto group-hover:visible group-hover:opacity-100">
                <div class="grid gap-0 rounded-sm border border-[#e7e7e7] bg-white p-2 shadow-xl">
                  {item.children.map((child) => (
                    <a href={child.href} class="border-b border-[#efefef] px-3 py-[10px] text-[13px] font-semibold text-[#777] transition last:border-b-0 hover:text-[var(--site-blue)]">
                      {child.label}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          ) : (
            <a href={item.href} class="text-[14px] font-semibold uppercase leading-none text-[#777] transition hover:text-[var(--site-blue)]">
              {item.label}
            </a>
          )
        )
      }
    </nav>
  </div>

  <details class="border-t border-[#efefef] lg:hidden">
    <summary class="pixel-container cursor-pointer list-none py-3 text-[12px] font-semibold uppercase text-[#777]">
      Menu
    </summary>
    <div class="pixel-container grid gap-2 pb-4">
      {
        mainNavigation.map((item) => (
          <div class="border border-[#e7e7e7]">
            <a href={item.href} class="block px-4 py-3 text-[12px] font-semibold uppercase text-[#777]">{item.label}</a>
            {item.children ? (
              <div class="grid gap-px border-t border-[#e7e7e7] bg-[#e7e7e7]">
                {item.children.map((child) => (
                  <a href={child.href} class="bg-white px-4 py-2 text-[12px] text-[#777]">
                    {child.label}
                  </a>
                ))}
              </div>
            ) : null}
          </div>
        ))
      }
    </div>
  </details>
</header>
